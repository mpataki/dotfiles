#!/usr/bin/env bash
# tmux status-right widget: counts of Claude Code sessions by state.
# Outputs an empty string when no sessions are active.
#
# Format (only non-zero counts shown):  cc 2W 1B 3I

set -u
PATH="$(cd "$(dirname "$0")" && pwd):$PATH"

w=0; b=0; i=0
while IFS=$'\t' read -r _ status _; do
  case "$status" in
    waiting) ((w++)) ;;
    busy)    ((b++)) ;;
    idle)    ((i++)) ;;
  esac
done < <(claude-panes 2>/dev/null)

[[ $((w + b + i)) -eq 0 ]] && exit 0

out="cc"
[[ $w -gt 0 ]] && out+=" ${w}W"
[[ $b -gt 0 ]] && out+=" ${b}B"
[[ $i -gt 0 ]] && out+=" ${i}I"

printf '%s' "$out"
